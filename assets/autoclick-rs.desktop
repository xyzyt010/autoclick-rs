[Desktop Entry]
Name=AutoClick-RS
GenericName=Automatic Key Presser
Comment=Cross-platform automatic key presser with native GUI
Exec=%HOME/.local/bin/autoclick-rs
Icon=%HOME/.local/share/icons/hicolor/256x256/apps/autoclick-rs.png
Terminal=false
Type=Application
Categories=Utility;Accessibility;
Keywords=autoclick;keypress;automation;macro;
StartupNotify=true
